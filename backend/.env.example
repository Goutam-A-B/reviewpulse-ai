# Copy to backend/.env and fill in. Every service below has a FREE tier — no card.

APP_ENV=dev

# --- Postgres: Supabase free tier ---
# Supabase → Project Settings → Database → Connection string (URI).
# Paste it as-is; the app rewrites postgresql:// to the asyncpg driver.
DATABASE_URL=

# --- Vectors: Qdrant Cloud free tier (1GB cluster) ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=review_vectors
# Or run Qdrant embedded (no server, no signup): set a local path, leave QDRANT_URL blank.
QDRANT_LOCAL_PATH=

# --- Reasoning: Groq free API (https://console.groq.com — free key, no card) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Synthesis: Gemini 2.5 Flash free tier (https://aistudio.google.com) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings: local, no key ---
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# --- Hard premium-call ceiling per report ---
PREMIUM_CALL_CEILING=1
# Deep Analysis mode: higher, still-bounded ceiling the user opts into.
DEEP_PREMIUM_CEILING=3

# --- Observability (optional, best-effort) ---
LANGSMITH_API_KEY=

FRONTEND_ORIGIN=http://localhost:3000
